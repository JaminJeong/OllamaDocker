# =============================================================================
# Ollama Docker Compose — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 환경변수 (민감 정보 포함)
# -----------------------------------------------------------------------------
.env
!.env.example

# -----------------------------------------------------------------------------
# Docker 볼륨 / 로컬 데이터
# -----------------------------------------------------------------------------
ollama_data/
webui_data/
data/

# -----------------------------------------------------------------------------
# JupyterLab 노트북
# -----------------------------------------------------------------------------
notebooks/.ipynb_checkpoints/
notebooks/**/.ipynb_checkpoints/
*.ipynb_checkpoints

# Jupyter 임시 파일
.jupyter/
__pycache__/
*.py[cod]
*.pyo

# -----------------------------------------------------------------------------
# OS 관련
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / 에디터
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# 로그
# -----------------------------------------------------------------------------
*.log
logs/
